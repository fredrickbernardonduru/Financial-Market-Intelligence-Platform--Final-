FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends curl \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir \
    flask==3.0.3 \
    flask-cors==4.0.1 \
    psycopg2-binary==2.9.9 \
    requests==2.31.0 \
    gunicorn==22.0.0 \
    python-dotenv==1.0.1

COPY api.py .
COPY static/ ./static/

EXPOSE 3000

CMD ["gunicorn", "--bind", "0.0.0.0:3000", "--workers", "2", "--timeout", "60", "api:app"]
